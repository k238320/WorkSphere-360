// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User Permisssions
model user {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  name                   String
  role_id                String?                  @unique @db.ObjectId
  super                  Boolean?                 @default(false)
  email                  String                   @unique
  password               String
  picture                String?
  designation            String?
  employement_code       String?                  @unique
  employement_code_dxb   String?                  @unique
  role_mapping           role_mapping[]
  project_permissions    project_permissions[]
  role                   roles?                   @relation(fields: [role_id], references: [id])
  created_at             DateTime?                @default(now())
  updated_at             DateTime?                @updatedAt
  status                 Boolean?                 @default(true)
  screenshot             Boolean?                 @default(false)
  screenshot_time        String                   @default("15")
  timeout_time           String                   @default("15")
  reset_token            String?
  reset_token_expires    DateTime?
  resource_id            String?                  @db.ObjectId
  app_session_token      String?
  app_verification_token String?
  token_expiration       DateTime?                @default(now())
  resource               resource?                @relation(fields: [resource_id], references: [id])
  task_permission        task_permission[]
  emp_attendance         emp_attendance[]
  user_details           user_details[]
  user_docs              user_docs[]
  assigned_asset         assigned_asset[]
  emp_leaves             emp_leaves[]
  asset_complaint        asset_complaint[]
  YearlyLeaveRecord      YearlyLeaveRecord[]
  extra_hours            extra_hours[]
  emp_activities         emp_activities[]
  UserApps               UserApps[]
  payslip                payslip[]
  resignation            resignation[]
  AttendanceWarningsSent AttendanceWarningsSent[]
}

model roles {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  role_mapping role_mapping[]
  created_at   DateTime?      @default(now())
  updated_at   DateTime?      @updatedAt
  status       Boolean?       @default(true)
  screens      Json?
  user         user?
}

model modules {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  role_mapping role_mapping[]
  created_at   DateTime?      @default(now())
  updated_at   DateTime?      @updatedAt
  status       Boolean?       @default(true)
}

model permission {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  role_mapping role_mapping[]
  created_at   DateTime?      @default(now())
  updated_at   DateTime?      @updatedAt
  status       Boolean?       @default(true)
}

model role_mapping {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  role_id       String     @unique @db.ObjectId
  role          roles      @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission_id String     @db.ObjectId
  permission    permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  module_id     String     @db.ObjectId
  modules       modules?   @relation(fields: [module_id], references: [id], onDelete: Cascade)
  user          user       @relation(fields: [role_id], references: [role_id])
  created_at    DateTime?  @default(now())
  updated_at    DateTime?  @updatedAt
  status        Boolean?   @default(true)
}

model screens {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  child      String
  route      String
  status     Boolean?  @default(true)
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
}

// Project
model project {
  id                       String                   @id @default(auto()) @map("_id") @db.ObjectId
  name                     String
  signed_document          String
  commercial_proposal      String?
  technical_proposal       String?
  mou_document             String?
  no_of_weeks              Int
  specific_timeline        String
  additional_documents     String?
  brief_commitments        String
  dicsounted_cost          Int
  reason                   String
  kickoff_date             String?
  project_plan             String?
  project_srs              String?
  status_report            String?
  project_website          String?
  project_categories       Json?
  project_technology       Json?
  project_industry         Json?
  project_hours            project_hours[]
  project_milestone        project_milestone[]
  weekly_status            weekly_status[]
  // project_permissions     project_permissions?     @relation(fields: [id], references: [project_id])
  project_status           project_status[]
  client_details           client_details[]
  created_at               DateTime?                @default(now())
  updated_at               DateTime?                @updatedAt
  status                   Boolean?                 @default(true)
  task                     task[]
  project_manager_details  Json?
  project_consumed_hours   project_consumed_hours[]
  pm_status                pm_status?
  go_live_date             String?
  project_win_date         DateTime?
  projectDivisionId        String?                  @db.ObjectId
  projectDivision          ProjectDivision?         @relation("DivisionProjects", fields: [projectDivisionId], references: [id])
  project_contract_type    project_contract_type?   @relation("project_contract_type", fields: [project_contract_type_id], references: [id])
  project_contract_type_id String?                  @db.ObjectId
  production_capacity      production_capacity[]
}

// Category 
model category {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  status     Boolean?  @default(true)
}

// technology
model technology {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  status     Boolean?  @default(true)
}

// industry
model industry {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  status     Boolean?  @default(true)
}

// Project Hours
model project_hours {
  id                       String                 @id @default(auto()) @map("_id") @db.ObjectId
  modified_date            String
  department_id            String                 @db.ObjectId
  department               department             @relation(fields: [department_id], references: [id])
  project_catgory_hours_id String                 @db.ObjectId
  project_category_hours   project_category_hours @relation(fields: [project_catgory_hours_id], references: [id])
  project_id               String                 @db.ObjectId
  project                  project                @relation(fields: [project_id], references: [id])
  no_of_resources          Int?
  hours                    Int
  role_id                  String                 @db.ObjectId
  created_at               DateTime?              @default(now())
  updated_at               DateTime?              @updatedAt
  status                   Boolean?               @default(true)
}

//project_category_hours
model project_category_hours {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  project_hours project_hours[]
  created_at    DateTime?       @default(now())
  updated_at    DateTime?       @updatedAt
  status        Boolean?        @default(true)
}

// department
model department {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  name                   String
  project_hours          project_hours[]
  cost                   cost[]
  created_at             DateTime?                @default(now())
  updated_at             DateTime?                @updatedAt
  resource               resource[]
  status                 Boolean?                 @default(true)
  project_consumed_hours project_consumed_hours[]
  allocation             allocation[]
  production_capacity    production_capacity[]
}

// Project Milestone
model project_milestone {
  id                    String              @id @default(auto()) @map("_id") @db.ObjectId
  project_id            String              @db.ObjectId
  project               project?            @relation(fields: [project_id], references: [id])
  milestone_phase_id    String              @db.ObjectId
  milestone_phase       milestone_phase     @relation(fields: [milestone_phase_id], references: [id])
  milestone_payment     Int
  targeted_month        String?
  delay_time            String?
  milestone             Json?
  onhold                Json?
  role_id               String
  user_id               String
  invoice               Boolean?
  invoice_date          String?
  payment_recieved      Boolean?
  payment_recieved_date String?
  is_upsell             Boolean             @default(false)
  is_initial_amount     Boolean             @default(false)
  document              String?
  created_at            DateTime?           @default(now())
  updated_at            DateTime?           @updatedAt
  status                Boolean?            @default(true)
  milestone_comment     milestone_comment[]
}

model milestone_comment {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  milestone_id String            @db.ObjectId
  milestone    project_milestone @relation(fields: [milestone_id], references: [id])
  user_id      String?           @db.ObjectId
  comment      String
  created_at   DateTime          @default(now())
  updated_at   DateTime?         @updatedAt
  status       Boolean?          @default(true)
}

// MilestonePhase
model milestone_phase {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  project_milestone project_milestone[]
  created_at        DateTime?           @default(now())
  updated_at        DateTime?           @updatedAt
  status            Boolean?            @default(true)
}

// WeeklyStatus
model weekly_status {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  project_id String    @db.ObjectId
  project    project   @relation(fields: [project_id], references: [id])
  commet     String
  user_id    String    @db.ObjectId
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  status     Boolean?  @default(true)
}

// Project Permission 
model project_permissions {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String    @db.ObjectId
  user       user      @relation(fields: [user_id], references: [id])
  project_id String?   @unique @db.ObjectId
  is_sale    Boolean   @default(false)
  is_pm      Boolean   @default(false)
  // project    project[]
  super      Boolean
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  status     Boolean?  @default(true)
}

// project_status
model project_status {
  id                         String                   @id @default(auto()) @map("_id") @db.ObjectId
  project_id                 String?                  @db.ObjectId
  project                    project?                 @relation(fields: [project_id], references: [id])
  porject_statuses_id        String                   @db.ObjectId
  project_statuses           project_statuses?        @relation(fields: [porject_statuses_id], references: [id])
  project_status_category_id String                   @db.ObjectId
  project_status_category    project_status_category? @relation(fields: [project_status_category_id], references: [id])
  user_id                    String                   @db.ObjectId
  days_delayed               Int?
  comment                    String
  created_at                 DateTime?                @default(now())
  updated_at                 DateTime?                @updatedAt
  status                     Boolean?                 @default(true)
}

// Project Statuses
model project_statuses {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  project_status project_status[]
  created_at     DateTime?        @default(now())
  updated_at     DateTime?        @updatedAt
  status         Boolean?         @default(true)
}

// ProjectStatusCategory
model project_status_category {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  project_status project_status[]
  created_at     DateTime?        @default(now())
  updated_at     DateTime?        @updatedAt
  status         Boolean?         @default(true)
}

// Cost

model cost {
  id                   String     @id @default(auto()) @map("_id") @db.ObjectId
  department_wise_cost Int
  start_date           DateTime
  department_id        String     @db.ObjectId
  department           department @relation(fields: [department_id], references: [id])
  created_at           DateTime?  @default(now())
  updated_at           DateTime?  @updatedAt
  status               Boolean?   @default(true)
}

// client details
model client_details {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  project_id  String    @db.ObjectId
  project     project   @relation(fields: [project_id], references: [id])
  name        String
  designation String?
  number      String
  email       String
  role_id     String
  status      Boolean?  @default(true)
  created_at  DateTime? @default(now())
  updated_at  DateTime? @updatedAt
}

model designation {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String // Senior, Mid, Junior, Intern
  resources resource[]
}

model capacity {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  value     Float // e.g. 0.8 for 80%
  resources resource[]
}

model rate {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  value     Float // e.g. 50 (per hour)
  resources resource[]
}

// resource   
model resource {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  status       Boolean? @default(true)
  is_team_lead Boolean? @default(false)

  designation_id String?      @db.ObjectId
  designation    designation? @relation(fields: [designation_id], references: [id])

  capacity_id String?   @db.ObjectId
  capacity    capacity? @relation(fields: [capacity_id], references: [id])

  rate_id String? @db.ObjectId
  rate    rate?   @relation(fields: [rate_id], references: [id])

  department_id       String                @db.ObjectId
  department          department?           @relation(fields: [department_id], references: [id])
  show_in_calendar    Boolean?              @default(true)
  is_atl              Boolean               @default(false)
  created_at          DateTime?             @default(now())
  updated_at          DateTime?             @updatedAt
  allocation          allocation[]
  per_date_allocation per_date_allocation[]
  user                user[]
  emp_leaves          emp_leaves[]
}

model task_category {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  status     Boolean?  @default(true)
  task       task[]
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
}

model task_status {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  task       task[]
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
}

